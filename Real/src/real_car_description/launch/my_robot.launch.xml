<launch>
    <let name="urdf_path"
         value="$(find-pkg-share real_car_description)/urdf/my_robot.urdf.xacro" />
    <let name="controller_config_path"
         value="$(find-pkg-share real_car_description)/config/my_robot_controllers.yaml" /> 
    <let name="cam_config_path"
         value="$(find-pkg-share ros2_camsense_x1)/config/config.yaml" />

     

    <node pkg="robot_state_publisher" exec="robot_state_publisher" output="screen">
        <param name="robot_description"
               value="$(command 'xacro $(var urdf_path)')" />
    </node>

    <node pkg="controller_manager" exec="ros2_control_node" output="both">
        <param name="robot_description"
               value="$(command 'xacro $(var urdf_path)')" />
               
        <param from="$(var controller_config_path)" />
    </node>

    <node pkg="controller_manager" exec="spawner" args="joint_state_broadcaster" output="screen" />
    
    <node pkg="controller_manager" exec="spawner" args="diff_drive_controller" output="screen" />

    <node pkg="ros2_camsense_x1" exec="camsense_x1_node">
        <param  from="$(var cam_config_path)" />
    </node>

    <node pkg="py_pkg" exec="mux_vel">
    </node>

    <node pkg="py_pkg" exec="mapodom_tf">
    </node>

    <node pkg="py_pkg" exec="path">
        <param name="use_sim_time"
               value="false" />
    </node>

    <node pkg="py_pkg" exec="pursuit">
        <param name="use_sim_time"
               value="false" />
    </node>

    <node pkg="py_pkg" exec="slam">
        <param name="use_sim_time"
               value="false" />
    </node>

</launch>