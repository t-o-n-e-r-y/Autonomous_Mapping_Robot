<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="base_height" value="0.15" />
    <xacro:property name="base_radius" value="0.125" />
    <xacro:property name="base_height_visual" value="0.005" />
    <xacro:property name="wheel_radius" value="0.0325" />
    <xacro:property name="wheel_length" value="0.025" />

    <xacro:property name="wheel_seperationdiv2" value="0.1336" />
    <!-- cai nay khac so voi cai gazebo vi thuc te xe phai cat bo phan bi dinh, (cai nay chi la hien thi nen khong sao) -->
    
    <xacro:property name="wheel_0point_y" value="0.055581" />

    <xacro:property name="lidar_length" value="0.07" />
    <xacro:property name="lidar_width" value="0.06" />
    <xacro:property name="lidar_height" value="0.05" />


    <xacro:property name="base_length" value="0.6" />
    <xacro:property name="base_width" value="0.4" />


    <link name="base_footprint" />

    <link name="base_link">
        <visual>
            <geometry>
                <!-- <box size="${base_length} ${base_width} ${base_height}" /> -->
                <cylinder radius="${base_radius}" length="${base_height_visual}" />
            </geometry>
                <origin xyz="0 0 ${base_height_visual / 2.0}" rpy="0 0 0" />
            <material name="wood" />
        </visual>
        <collision>
            <geometry>
                <!-- <box size="${base_length} ${base_width} ${base_height}" /> -->
                <cylinder radius="${base_radius}" length="${base_height}" />
            </geometry>
            <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0" />
        </collision>
            <xacro:cylinder_inertia m="1.0" r="${base_radius}" l="${base_height}" 
                                    o_xyz="0 0 0" o_rpy="0 0 0" />
    </link>

    <link name="lidar_link">
        <visual>
            <geometry>
                <box size="${lidar_length} ${lidar_width} ${lidar_height}" />
            </geometry>
                <origin xyz="0 0 ${lidar_height / 2.0}" rpy="0 0 0" />
            <material name="yellow" />
        </visual>
        <collision>
            <geometry>
                <box size="${lidar_length} ${lidar_width} ${lidar_height}" />
            </geometry>
            <origin xyz="0 0 ${lidar_height / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:box_inertia m="0.2" x="${lidar_length}" y="${lidar_width}" z="${lidar_height}" 
                           o_xyz="0 0 ${lidar_height / 2.0}" o_rpy="0 0 0" />
    </link>
    
    <link name="second_base_link">
        <visual>
            <geometry>
                <!-- <box size="${base_length} ${base_width} ${base_height}" /> -->
                <cylinder radius="${base_radius / 1.5}" length="${base_height_visual}" />
            </geometry>
                <origin xyz="0 0 ${base_height_visual / 2.0}" rpy="0 0 0" />
            <material name="pink" />
        </visual>
    </link>

    <xacro:macro name="wheel_link" params="prefix">
        <link name="${prefix}_wheel_link">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
                <material name="gray" />
            </visual>
            <collision>
                <geometry>
                    <sphere radius="${wheel_radius}" />
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0" />
            </collision>
            <xacro:cylinder_inertia m="1.0" r="${wheel_radius}" l="${wheel_length}" 
                                    o_xyz="0 0 0" o_rpy="${pi / 2.0} 0 0" />
        </link>
    </xacro:macro>

    <xacro:wheel_link prefix="right" />
    <xacro:wheel_link prefix="left" />

    <link name="caster_wheel_link">
        <visual>
            <geometry>
                <sphere radius="${wheel_radius / 2.0}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="gray" />
        </visual>
        <collision>
            <geometry>
                <sphere radius="${wheel_radius / 2.0}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>
        <xacro:sphere_inertia m="0.5" r="${wheel_radius / 2.0}" 
                              o_xyz="0 0 0" o_rpy="0 0 0" />
    </link>

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="${wheel_0point_y}  0 ${wheel_radius}" rpy="0 0 0" />
    </joint>

    <joint name="base_lidar" type="fixed">
        <parent link="base_link" />
        <child link="lidar_link" />
        <origin xyz="0  0 ${base_height}" rpy="0 0 0" />
    </joint>

    <joint name="base_second_base" type="fixed">
        <parent link="base_link" />
        <child link="second_base_link" />
        <origin xyz="0  0 ${base_height}" rpy="0 0 0" />
    </joint>

    <joint name="base_right_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_link" />
        <origin xyz="${-wheel_0point_y} ${-(wheel_seperationdiv2) / 1.0} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_left_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_link" />
        <origin xyz="${-wheel_0point_y} ${(wheel_seperationdiv2) / 1.0} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_caster_wheel_joint" type="fixed">
        <parent link="base_link" />
        <child link="caster_wheel_link" />
        <origin xyz="${base_radius / 2.0} 0 ${-wheel_radius / 2.0}" rpy="0 0 0" />
    </joint>

</robot>